<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingTop="10dp" android:paddingBottom="10dp">
    <TextView android:id="@+id/tvParticipantInitial"
        android:layout_width="44dp" android:layout_height="44dp"
        android:gravity="center" android:textSize="18sp" android:textStyle="bold"
        android:textColor="@android:color/white" android:layout_marginEnd="12dp"
        android:background="@drawable/circle_avatar"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvParticipantName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="15sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface"/>
        <TextView android:id="@+id/tvPaidStatus"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="12sp"/>
    </LinearLayout>
    <TextView android:id="@+id/tvParticipantShare"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="16sp" android:textStyle="bold" android:textColor="?attr/colorPrimary"
        android:layout_marginEnd="8dp"/>
    <Button android:id="@+id/btnMarkPaid"
        android:layout_width="wrap_content" android:layout_height="32dp"
        android:text="Paid" android:textSize="11sp"
        style="@style/Widget.Material3.Button.TonalButton"/>
</LinearLayout>
